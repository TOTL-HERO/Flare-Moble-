# ─── FAL AI ────────────────────────────────────────────────────────────────────
# Image & video generation (https://fal.ai/dashboard/keys)
FAL_KEY=

# ─── Anthropic ─────────────────────────────────────────────────────────────────
# Claude API for AI copy/SEO engine (https://console.anthropic.com/keys)
ANTHROPIC_API_KEY=

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and anon key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — keep server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Secret key for server-side Stripe calls
STRIPE_SECRET_KEY=
# Signing secret for webhook endpoint verification
STRIPE_WEBHOOK_SECRET=
# Price IDs for each subscription tier
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ─── Runway ML ─────────────────────────────────────────────────────────────────
# Video generation (https://app.runwayml.com/settings/api)
RUNWAY_API_KEY=

# ─── App ───────────────────────────────────────────────────────────────────────
# Public base URL (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=
